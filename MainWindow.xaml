<Window x:Class="CybersecurityAwarenessBot_Part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot - Part 2" Height="720" Width="980"
        WindowStartupLocation="CenterScreen" Background="#0F172A">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827" CornerRadius="18" Padding="18" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="105" Height="105" Background="#1E293B" CornerRadius="16" Padding="8" Margin="0,0,16,0">
                    <TextBlock Text="🛡️" FontSize="56" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Cybersecurity Awareness Bot" Foreground="White" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="Part 2: GUI, Keyword Recognition, Random Responses, Memory and Sentiment Detection"
                               Foreground="#CBD5E1" FontSize="15" Margin="0,6,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="Ask me about password safety, phishing, scams, privacy, malware or social engineering."
                               Foreground="#94A3B8" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#111827" CornerRadius="18" Padding="16" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="ASCII Logo" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                    <Border Background="#020617" CornerRadius="12" Padding="10">
                        <TextBlock x:Name="AsciiLogoTextBlock" FontFamily="Consolas" FontSize="10" Foreground="#38BDF8" TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Quick topics" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,18,0,10" />
                    <WrapPanel>
                        <Button Content="Password" Click="QuickTopic_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="0,0,8,8" Padding="10,6" />
                        <Button Content="Phishing" Click="QuickTopic_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="0,0,8,8" Padding="10,6" />
                        <Button Content="Privacy" Click="QuickTopic_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="0,0,8,8" Padding="10,6" />
                        <Button Content="Scam" Click="QuickTopic_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="0,0,8,8" Padding="10,6" />
                        <Button Content="Malware" Click="QuickTopic_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Margin="0,0,8,8" Padding="10,6" />
                    </WrapPanel>

                    <TextBlock Text="Memory" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,18,0,10" />
                    <TextBlock x:Name="MemoryTextBlock" Foreground="#CBD5E1" TextWrapping="Wrap" Text="No user details saved yet." />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#111827" CornerRadius="18" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Chat" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ChatPanel" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#111827" CornerRadius="18" Padding="14" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputTextBox" Grid.Column="0" Height="44" FontSize="15" Padding="12"
                         VerticalContentAlignment="Center" KeyDown="UserInputTextBox_KeyDown"
                         ToolTip="Type your cybersecurity question here" />
                <Button Grid.Column="1" Content="Send" Width="100" Height="44" Margin="10,0,0,0" Click="SendButton_Click"
                        Background="#2563EB" Foreground="White" FontWeight="Bold" />
                <Button Grid.Column="2" Content="Clear" Width="90" Height="44" Margin="10,0,0,0" Click="ClearButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
